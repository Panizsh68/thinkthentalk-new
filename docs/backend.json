
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Unified identity across phone and email providers.",
      "type": "object",
      "properties": {
        "firstNameFa": {
          "type": "string",
          "description": "User's first name in Persian"
        },
        "lastNameFa": {
          "type": "string",
          "description": "User's last name in Persian"
        },
        "mobile": {
          "type": "string",
          "description": "Primary mobile number (legacy compatibility)"
        },
        "phone": {
          "type": "string",
          "description": "Verified phone number from Auth"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Verified email address from Auth"
        },
        "primaryLoginMethod": {
          "type": "string",
          "description": "The provider ID used during account creation"
        },
        "linkedProviders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of all auth providers linked to this UID"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "auth": {
    "providers": [
      "phone",
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Stores user identity and profile metadata."
    }
  }
}
