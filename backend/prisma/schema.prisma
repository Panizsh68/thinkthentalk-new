
generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  EVENT_MANAGER
  FINANCE
}

enum EventType {
  ONLINE
  OFFLINE
}

enum TicketType {
  EARLY_BIRD
  STANDARD
  SUPPORTER
}

enum Currency {
  IRR
  TOMAN
}

enum RegistrationStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ResourceAccessLevel {
  PUBLIC
  REGISTERED_ONLY
}

enum DiscountType {
  PERCENT
  FIXED
}

enum ContactMessageStatus {
  NEW
  SEEN
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EventIdeaType {
  TOPIC
  FORMAT
  VENUE
  OTHER
}

enum EventIdeaStatus {
  PENDING
  REVIEWED
  PLANNED
  REJECTED
}

enum PartnershipStatus {
  PENDING
  REVIEWING
  CONTACTED
  ACCEPTED
  REJECTED
}

enum SponsorshipPlan {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  PURCHASE
  REFUND
  SUBSCRIPTION
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

model AdminUser {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id             String         @id @default(uuid())
  mobile         String         @unique
  email          String?        @unique
  password       String?
  firstNameFa    String
  lastNameFa     String
  firstNameEn    String?
  lastNameEn     String?
  gender         Gender?
  age            Int?
  educationLevel String?
  fieldOfStudy   String?
  isEmployed     Boolean?       @default(false)
  jobTitle       String?
  languageLevel  String?
  avatarUrl      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  registrations  Registration[]
  eventIdeas     EventIdea[]
  collabRequests CollaborationRequest[]
  sponsorRequests SponsorshipRequest[]
  wallet         Wallet?
  withdrawalRequests WithdrawalRequest[]
  evaluationSubmissions EvaluationSubmission[]
}

model Event {
  id                    String                 @id @default(uuid())
  slug                  String                 @unique
  title                 String
  summaryFa             String                 @db.Text
  summaryEn             String?                @db.Text
  descriptionFa         String                 @db.Text
  descriptionEn         String?                @db.Text
  type                  EventType
  address               String?                @db.Text
  city                  String?
  startDateTime         DateTime
  endDateTime           DateTime?
  capacityTotal         Int
  capacityRemaining     Int
  showRemainingCapacity Boolean                @default(false)
  categories            Json?
  publicDiscountIds     Json?
  posterUrl             String?
  isArchived            Boolean                @default(false)
  archivedAt            DateTime?
  archivedById          String?
  deletedAt             DateTime?
  deletedById           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  ticketConfigs         EventTicketConfig[]
  resources             EventResource[]
  registrations         Registration[]
  discounts             DiscountOnEvent[]
  evaluationForm        EvaluationForm?
}

model EventTicketConfig {
  id               String     @id @default(uuid())
  eventId          String
  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type             TicketType
  price            Decimal    @db.Decimal(15, 2)
  currency         Currency   @default(TOMAN)
  quantityTotal    Int
  quantitySold     Int        @default(0)
  saleStartDate    DateTime?
  saleEndDate      DateTime?
  earlyBirdEndDate DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([eventId, type])
}

model EventResource {
  id          String              @id @default(uuid())
  eventId     String
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  titleFa     String
  titleEn     String
  accessLevel ResourceAccessLevel @default(PUBLIC)
  url         String
  description String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Registration {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  eventId    String
  event      Event              @relation(fields: [eventId], references: [id])
  ticketType TicketType
  status     RegistrationStatus @default(PENDING)
  formData   Json?
  paymentId  String?            @unique
  payment    Payment?           @relation(fields: [paymentId], references: [id])
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([userId, eventId])
}

model Payment {
  id                   String        @id @default(uuid())
  registrationId       String?
  eventId              String
  ticketType           TicketType
  amount               Decimal       @db.Decimal(15, 2)
  currency             Currency      @default(TOMAN)
  status               PaymentStatus @default(PENDING)
  gatewayTransactionId String?       @unique
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  registration         Registration?
}

model Discount {
  id             String            @id @default(uuid())
  name           String
  code           String?           @unique
  type           DiscountType
  value          Decimal           @db.Decimal(15, 2)
  maxUses        Int?
  usedCount      Int               @default(0)
  maxUsesPerUser Int?              @default(1)
  minAmount      Decimal?          @db.Decimal(15, 2)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean           @default(true)
  isPublic       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  events         DiscountOnEvent[]
}

model DiscountOnEvent {
  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([discountId, eventId])
}

model ContactMessage {
  id          String               @id @default(uuid())
  name        String?
  email       String
  message     String               @db.Text
  source      String               @default("public-web")
  ipAddress   String?
  userAgent   String?
  language    String               @default("en")
  status      ContactMessageStatus @default(NEW)
  processedAt DateTime?
  emailSent   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model EventIdea {
  id          String          @id @default(uuid())
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])
  name        String?
  email       String?
  title       String
  description String          @db.Text
  type        EventIdeaType
  status      EventIdeaStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model CollaborationRequest {
  id               String            @id @default(uuid())
  userId           String?
  user             User?             @relation(fields: [userId], references: [id])
  name             String
  email            String
  mobile           String
  fieldOfExpertise String
  experience       String?           @db.Text
  whyJoin          String            @db.Text
  availability     String?
  status           PartnershipStatus @default(PENDING)
  notes            String?           @db.Text
  processedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model SponsorshipRequest {
  id                 String            @id @default(uuid())
  userId             String?
  user               User?             @relation(fields: [userId], references: [id])
  companyName        String
  representativeName String
  email              String
  mobile             String
  plan               SponsorshipPlan
  description        String?           @db.Text
  status             PartnershipStatus @default(PENDING)
  notes              String?           @db.Text
  processedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id])
  balance      Decimal             @default(0) @db.Decimal(15, 2)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id])
  amount      Decimal               @db.Decimal(15, 2)
  type        WalletTransactionType
  description String?
  referenceId String?
  status      PaymentStatus         @default(PENDING)
  createdAt   DateTime              @default(now())
}

model WithdrawalRequest {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  amount      Decimal          @db.Decimal(15, 2)
  shabaNumber String
  status      WithdrawalStatus @default(PENDING)
  adminNote   String?
  processedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Decimal  @db.Decimal(15, 2)
  durationDays Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  planName  String
  startDate DateTime @default(now())
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvaluationForm {
  id        String               @id @default(uuid())
  eventId   String               @unique
  event     Event                @relation(fields: [eventId], references: [id])
  questions EvaluationQuestion[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model EvaluationQuestion {
  id       String                 @id @default(uuid())
  formId   String
  form     EvaluationForm         @relation(fields: [formId], references: [id], onDelete: Cascade)
  type     EvaluationQuestionType
  label    String
  required Boolean                @default(true)
}

model EvaluationSubmission {
  id               String   @id @default(uuid())
  evaluationFormId String
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  eventId          String
  answers          Json
  submittedAt      DateTime @default(now())
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  createdAt    DateTime @default(now())
}

model EventAudit {
  id              String   @id @default(uuid())
  eventId         String
  eventIdSnapshot String
  action          String
  byUserId        String?
  meta            Json?
  createdAt       DateTime @default(now())
}
