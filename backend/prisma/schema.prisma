generator client {
  provider = "prisma-client-js"
  previewFeatures = ["adapter-mariadb"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  mobile          String         @unique
  firstNameFa     String?
  lastNameFa      String?
  firstNameEn     String?
  lastNameEn      String?
  gender          Gender?
  age             Int?
  educationLevel  String?
  fieldOfStudy    String?
  isEmployed      Boolean?       @default(false)
  jobTitle        String?
  email           String?
  languageLevel   String?
  avatarUrl       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  registrations   Registration[]
  submissions     EvaluationSubmission[]
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  role         AdminRole @default(EVENT_MANAGER)
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Event {
  id                    String              @id @default(uuid())
  slug                  String              @unique
  title                 String              @db.Text
  summaryFa             String              @db.Text
  summaryEn             String?             @db.Text
  descriptionFa         String              @db.Text
  descriptionEn         String?             @db.Text
  type                  EventType           @default(OFFLINE)
  city                  String?             @db.Text
  address               String?             @db.Text
  startDateTime         DateTime
  endDateTime           DateTime?
  capacityTotal         Int
  capacityRemaining     Int
  showRemainingCapacity Boolean             @default(false)
  categories            Json
  publicDiscountIds     Json
  posterUrl             String?
  isArchived            Boolean             @default(false)
  archivedAt            DateTime?
  archivedById          String?
  deletedAt             DateTime?
  deletedById           String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  ticketConfigs         EventTicketConfig[]
  resources             EventResource[]
  registrations         Registration[]
  evaluationForm        EvaluationForm?
  auditLogs             EventAudit[]
}

model EventTicketConfig {
  id               String     @id @default(uuid())
  eventId          String
  type             TicketType
  price            Decimal    @db.Decimal(15, 2)
  currency         Currency   @default(TOMAN)
  quantityTotal    Int
  quantitySold     Int        @default(0)
  saleStartDate    DateTime?
  saleEndDate      DateTime?
  earlyBirdEndDate DateTime?
  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, type])
}

model EventResource {
  id          String              @id @default(uuid())
  eventId     String
  titleFa     String
  titleEn     String
  accessLevel ResourceAccessLevel @default(PUBLIC)
  url         String
  description String?             @db.Text
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Registration {
  id         String             @id @default(uuid())
  userId     String
  eventId    String
  ticketType TicketType
  status     RegistrationStatus @default(PENDING)
  formData   Json
  paymentId  String?            @unique
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  user       User               @relation(fields: [userId], references: [id])
  event      Event              @relation(fields: [eventId], references: [id])
  payment    Payment?           @relation("RegistrationPayment", fields: [paymentId], references: [id])
}

model Payment {
  id                   String        @id @default(uuid())
  registrationId       String        @unique
  eventId              String
  ticketType           TicketType
  amount               Decimal       @db.Decimal(15, 2)
  currency             Currency      @default(TOMAN)
  status               PaymentStatus @default(PENDING)
  gatewayTransactionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  registration         Registration? @relation("RegistrationPayment")
}

model Discount {
  id               String            @id @default(uuid())
  name             String
  code             String?           @unique
  type             DiscountType      @default(PERCENT)
  value            Decimal           @db.Decimal(15, 2)
  maxUses          Int?
  usedCount        Int               @default(0)
  maxUsesPerUser   Int?
  minAmount        Decimal?          @db.Decimal(15, 2)
  startDate        DateTime
  endDate          DateTime
  isActive         Boolean           @default(true)
  isPublic         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  events           DiscountOnEvent[]
}

model DiscountOnEvent {
  discountId String
  eventId    String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@id([discountId, eventId])
}

model Sponsor {
  id               String   @id @default(uuid())
  name             String
  productOrTagline String
  logoUrl          String
  websiteUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(uuid())
  name      String
  role      String
  photoUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id          String               @id @default(uuid())
  name        String?
  email       String
  message     String               @db.Text
  source      String               @default("public-web")
  ipAddress   String?
  userAgent   String?
  language    String               @default("fa")
  status      ContactMessageStatus @default(NEW)
  processedAt DateTime?
  emailSent   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model EvaluationForm {
  id        String               @id @default(uuid())
  eventId   String               @unique
  event     Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions EvaluationQuestion[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model EvaluationQuestion {
  id       String                 @id @default(uuid())
  formId   String
  type     EvaluationQuestionType
  label    String
  required Boolean                @default(true)
  form     EvaluationForm         @relation(fields: [formId], references: [id], onDelete: Cascade)
}

model EvaluationSubmission {
  id               String   @id @default(uuid())
  evaluationFormId String
  userId           String
  eventId          String
  answers          Json
  submittedAt      DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
}

model EventAudit {
  id              String   @id @default(uuid())
  eventId         String
  eventIdSnapshot String
  action          String
  byUserId        String?
  meta            Json?
  createdAt       DateTime @default(now())
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  createdAt    DateTime @default(now())
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AdminRole {
  ADMIN
  EVENT_MANAGER
  FINANCE
}

enum EventType {
  ONLINE
  OFFLINE
}

enum TicketType {
  EARLY_BIRD
  STANDARD
  SUPPORTER
}

enum Currency {
  IRR
  TOMAN
}

enum ResourceAccessLevel {
  PUBLIC
  REGISTERED_ONLY
}

enum RegistrationStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum ContactMessageStatus {
  NEW
  SEEN
  ARCHIVED
}

enum EvaluationQuestionType {
  RATING
  TEXT
  YES_NO
}
