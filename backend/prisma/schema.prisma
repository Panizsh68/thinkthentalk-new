// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  EVENT_MANAGER
  FINANCE
}

enum EventType {
  ONLINE
  OFFLINE
}

enum TicketType {
  EARLY_BIRD
  STANDARD
  SUPPORTER
}

enum Currency {
  IRR
  TOMAN
}

enum RegistrationStatus {
  PAID
  PENDING
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ResourceAccessLevel {
  PUBLIC
  REGISTERED_ONLY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ContactMessageStatus {
  NEW
  SEEN
  ARCHIVED
}

model User {
  id             String         @id @default(uuid())
  mobile         String         @unique
  firstNameFa    String         @default("نام")
  lastNameFa     String         @default("نام خانوادگی")
  firstNameEn    String?
  lastNameEn     String?
  gender         Gender?
  age            Int?
  educationLevel String?
  fieldOfStudy   String?
  isEmployed     Boolean        @default(false)
  jobTitle       String?
  email          String?
  languageLevel  String?
  avatarUrl      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  registrations  Registration[]
  EvaluationSubmission EvaluationSubmission[]
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  role         AdminRole @default(ADMIN)
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  AuditLogs    AdminAuditLog[]
}

model Event {
  id                    String              @id @default(uuid())
  slug                  String              @unique
  title                 String              @db.Text // JSON string: {fa, en}
  summaryFa             String              @db.Text
  summaryEn             String              @db.Text
  descriptionFa         String              @db.LongText
  descriptionEn         String              @db.LongText
  type                  EventType           @default(ONLINE)
  address               String?             @db.Text
  city                  String?             @db.Text // JSON string: {fa, en}
  startDateTime         DateTime
  endDateTime           DateTime?
  capacityTotal         Int
  capacityRemaining     Int
  showRemainingCapacity Boolean             @default(false)
  categories            Json                // Array of strings
  publicDiscountIds     Json                // Array of strings
  posterUrl             String?             @db.Text
  isArchived            Boolean             @default(false)
  archivedAt            DateTime?
  archivedById          String?
  deletedAt             DateTime?
  deletedById           String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  ticketConfigs         EventTicketConfig[]
  resources             EventResource[]
  registrations         Registration[]
  EvaluationForm        EvaluationForm?
  AuditLogs             EventAudit[]
  discounts             DiscountOnEvent[]
}

model EventTicketConfig {
  id               String     @id @default(uuid())
  eventId          String
  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type             TicketType
  price            Decimal    @db.Decimal(15, 2)
  currency         Currency   @default(TOMAN)
  quantityTotal    Int
  quantitySold     Int        @default(0)
  saleStartDate    DateTime?
  saleEndDate      DateTime?
  earlyBirdEndDate DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([eventId, type])
}

model EventResource {
  id          String              @id @default(uuid())
  eventId     String
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  titleFa     String
  titleEn     String
  description String?             @db.Text
  accessLevel ResourceAccessLevel @default(PUBLIC)
  url         String              @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Registration {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  eventId    String
  event      Event              @relation(fields: [eventId], references: [id])
  ticketType TicketType
  status     RegistrationStatus @default(PENDING)
  formData   Json?
  paymentId  String?            @unique
  payment    Payment?           @relation("RegistrationPayment")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model Payment {
  id                   String        @id @default(uuid())
  registrationId       String        @unique
  registration         Registration  @relation("RegistrationPayment", fields: [registrationId], references: [id], onDelete: Cascade)
  eventId              String
  ticketType           TicketType
  amount               Decimal       @db.Decimal(15, 2)
  currency             Currency
  status               PaymentStatus @default(PENDING)
  gatewayTransactionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Discount {
  id             String            @id @default(uuid())
  name           String
  code           String?           @unique
  type           String            // PERCENT | FIXED
  value          Decimal           @db.Decimal(15, 2)
  maxUses        Int?
  usedCount      Int               @default(0)
  maxUsesPerUser Int?
  minAmount      Decimal?          @db.Decimal(15, 2)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean           @default(true)
  isPublic       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  events         DiscountOnEvent[]
}

model DiscountOnEvent {
  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([discountId, eventId])
}

model EvaluationForm {
  id        String               @id @default(uuid())
  eventId   String               @unique
  event     Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  questions EvaluationQuestion[]
}

model EvaluationQuestion {
  id       String    @id @default(uuid())
  formId   String
  form     EvaluationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  type     String    // RATING | TEXT | YES_NO
  label    String    @db.Text
  required Boolean   @default(true)
}

model EvaluationSubmission {
  id               String   @id @default(uuid())
  evaluationFormId String
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  eventId          String
  answers          Json     // Key-value pairs
  submittedAt      DateTime @default(now())
}

model ContactMessage {
  id          String               @id @default(uuid())
  name        String?
  email       String
  message     String               @db.LongText
  source      String               @default("public-web")
  ipAddress   String?
  userAgent   String?              @db.Text
  language    String               @default("en")
  status      ContactMessageStatus @default(NEW)
  processedAt DateTime?
  emailSent   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String
  admin        AdminUser @relation(fields: [adminId], references: [id])
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  timestamp    DateTime @default(now())
}

model EventAudit {
  id              String   @id @default(uuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventIdSnapshot String
  action          String
  byUserId        String?
  meta            Json?
  createdAt       DateTime @default(now())
}
