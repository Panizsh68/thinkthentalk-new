generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["adapter-mariadb"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  EVENT_MANAGER
  FINANCE
}

enum EventType {
  ONLINE
  OFFLINE
}

enum TicketType {
  EARLY_BIRD
  STANDARD
  SUPPORTER
}

enum Currency {
  IRR
  TOMAN
}

enum ResourceAccessLevel {
  PUBLIC
  REGISTERED_ONLY
}

enum RegistrationStatus {
  PAID
  PENDING
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum ContactMessageStatus {
  NEW
  SEEN
  ARCHIVED
}

enum EvaluationQuestionType {
  RATING
  TEXT
  YES_NO
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  role         AdminRole @default(EVENT_MANAGER)
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  id             String                   @id @default(uuid())
  mobile         String                   @unique
  firstNameFa    String
  lastNameFa     String
  firstNameEn    String?
  lastNameEn     String?
  gender         String?
  age            Int?
  educationLevel String?
  fieldOfStudy   String?
  isEmployed     Boolean?                 @default(false)
  jobTitle       String?
  email          String?
  languageLevel  String?
  avatarUrl      String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  registrations  Registration[]
  evaluations    EvaluationSubmission[]
}

model Event {
  id                    String               @id @default(uuid())
  slug                  String               @unique
  title                 String               @db.Text // JSON String
  summaryFa             String               @db.Text
  summaryEn             String?              @db.Text
  descriptionFa         String               @db.Text
  descriptionEn         String?              @db.Text
  type                  EventType            @default(OFFLINE)
  address               String?              @db.Text
  city                  String?              @db.Text // JSON String
  startDateTime         DateTime
  endDateTime           DateTime?
  capacityTotal         Int
  capacityRemaining     Int
  showRemainingCapacity Boolean              @default(false)
  categories            Json? // Array of strings
  posterUrl             String?              @db.Text
  publicDiscountIds     Json? // Array of discount IDs
  isArchived            Boolean              @default(false)
  archivedAt            DateTime?
  archivedById          String?
  deletedAt             DateTime?
  deletedById           String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  ticketConfigs         EventTicketConfig[]
  resources             EventResource[]
  registrations         Registration[]
  discounts             DiscountOnEvent[]
  evaluationForm        EvaluationForm?
}

model EventTicketConfig {
  id               String     @id @default(uuid())
  eventId          String
  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type             TicketType
  price            Decimal    @db.Decimal(15, 2)
  currency         Currency   @default(TOMAN)
  quantityTotal    Int
  quantitySold     Int        @default(0)
  saleStartDate    DateTime?
  saleEndDate      DateTime?
  earlyBirdEndDate DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([eventId, type])
}

model EventResource {
  id          String              @id @default(uuid())
  eventId     String
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  titleFa     String
  titleEn     String
  accessLevel ResourceAccessLevel @default(PUBLIC)
  url         String              @db.Text
  description String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Registration {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  eventId    String
  event      Event              @relation(fields: [eventId], references: [id])
  ticketType TicketType
  status     RegistrationStatus @default(PENDING)
  formData   Json?
  paymentId  String?            @unique
  payment    Payment?           @relation("RegistrationPayment")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([userId, eventId])
}

model Payment {
  id                   String        @id @default(uuid())
  registrationId       String        @unique
  registration         Registration  @relation("RegistrationPayment", fields: [registrationId], references: [id])
  eventId              String
  ticketType           TicketType
  amount               Decimal       @db.Decimal(15, 2)
  currency             Currency      @default(TOMAN)
  status               PaymentStatus @default(PENDING)
  gatewayTransactionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Discount {
  id             String            @id @default(uuid())
  name           String
  code           String?           @unique
  type           DiscountType
  value          Decimal           @db.Decimal(15, 2)
  maxUses        Int?
  usedCount      Int               @default(0)
  maxUsesPerUser Int?
  minAmount      Decimal?          @db.Decimal(15, 2)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean           @default(true)
  isPublic       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  events         DiscountOnEvent[]
}

model DiscountOnEvent {
  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([discountId, eventId])
}

model ContactMessage {
  id          String               @id @default(uuid())
  name        String?
  email       String
  message     String               @db.Text
  source      String               @default("public-web")
  ipAddress   String?
  userAgent   String?
  language    String               @default("fa")
  status      ContactMessageStatus @default(NEW)
  processedAt DateTime?
  emailSent   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model EvaluationForm {
  id          String                 @id @default(uuid())
  eventId     String                 @unique
  event       Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  questions   EvaluationQuestion[]
  submissions EvaluationSubmission[]
}

model EvaluationQuestion {
  id        String                 @id @default(uuid())
  formId    String
  form      EvaluationForm         @relation(fields: [formId], references: [id], onDelete: Cascade)
  type      EvaluationQuestionType
  label     String                 @db.Text
  required  Boolean                @default(true)
  order     Int                    @default(0)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
}

model EvaluationSubmission {
  id               String         @id @default(uuid())
  evaluationFormId String
  evaluationForm   EvaluationForm @relation(fields: [evaluationFormId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  eventId          String
  answers          Json // Record<questionId, answer>
  submittedAt      DateTime       @default(now())
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  createdAt    DateTime @default(now())
}

model EventAudit {
  id              String   @id @default(uuid())
  eventId         String
  eventIdSnapshot String
  action          String
  byUserId        String?
  meta            Json?
  createdAt       DateTime @default(now())
}
