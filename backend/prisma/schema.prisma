generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  EVENT_MANAGER
  FINANCE
}

enum EventType {
  ONLINE
  OFFLINE
}

enum TicketType {
  EARLY_BIRD
  STANDARD
  SUPPORTER
}

enum Currency {
  IRR
  TOMAN
}

enum ResourceAccessLevel {
  PUBLIC
  REGISTERED_ONLY
}

enum RegistrationStatus {
  PAID
  PENDING
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum ContactMessageStatus {
  NEW
  SEEN
  ARCHIVED
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  role         AdminRole @default(ADMIN)
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  id             String         @id @default(uuid())
  mobile         String         @unique
  firstNameFa    String         @default("نام")
  lastNameFa     String         @default("نام خانوادگی")
  firstNameEn    String?
  lastNameEn     String?
  gender         String?
  age            Int?
  educationLevel String?
  fieldOfStudy   String?
  isEmployed     Boolean?
  jobTitle       String?
  email          String?
  languageLevel  String?
  avatarUrl      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  registrations  Registration[]
}

model Event {
  id                    String               @id @default(uuid())
  slug                  String               @unique
  title                 String               @db.Text
  summaryFa             String               @db.Text
  summaryEn             String?              @db.Text
  descriptionFa         String               @db.LongText
  descriptionEn         String?              @db.LongText
  type                  EventType            @default(ONLINE)
  city                  String?              @db.Text
  address               String?              @db.Text
  startDateTime         DateTime
  endDateTime           DateTime?
  capacityTotal         Int                  @default(0)
  capacityRemaining     Int                  @default(0)
  showRemainingCapacity Boolean              @default(false)
  categories            Json?
  publicDiscountIds     Json?
  posterUrl             String?              @db.Text
  isArchived            Boolean              @default(false)
  archivedAt            DateTime?
  archivedById          String?
  deletedAt             DateTime?
  deletedById           String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  ticketConfigs         EventTicketConfig[]
  resources             EventResource[]
  registrations         Registration[]
  discounts             DiscountOnEvent[]
  payments              Payment[]
}

model EventTicketConfig {
  id               String     @id @default(uuid())
  eventId          String
  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type             TicketType
  price            Decimal    @db.Decimal(15, 2)
  currency         Currency   @default(TOMAN)
  quantityTotal    Int        @default(0)
  quantitySold     Int        @default(0)
  saleStartDate    DateTime?
  saleEndDate      DateTime?
  earlyBirdEndDate DateTime?

  @@unique([eventId, type])
}

model EventResource {
  id          String              @id @default(uuid())
  eventId     String
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  titleFa     String
  titleEn     String
  description String?             @db.Text
  accessLevel ResourceAccessLevel @default(PUBLIC)
  url         String              @db.Text
}

model Registration {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType TicketType
  status     RegistrationStatus @default(PENDING)
  formData   Json?
  paymentId  String?            @unique
  payment    Payment?           @relation("RegPayment")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model Payment {
  id                   String        @id @default(uuid())
  registrationId       String        @unique
  registration         Registration  @relation("RegPayment", fields: [registrationId], references: [id], onDelete: Cascade)
  eventId              String
  event                Event         @relation(fields: [eventId], references: [id])
  ticketType           TicketType
  amount               Decimal       @db.Decimal(15, 2)
  currency             Currency      @default(TOMAN)
  status               PaymentStatus @default(PENDING)
  gatewayTransactionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Discount {
  id             String            @id @default(uuid())
  name           String
  code           String?           @unique
  type           DiscountType
  value          Decimal           @db.Decimal(15, 2)
  maxUses        Int?
  usedCount      Int               @default(0)
  maxUsesPerUser Int?
  minAmount      Decimal?          @db.Decimal(15, 2)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean           @default(true)
  isPublic       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  events         DiscountOnEvent[]
}

model DiscountOnEvent {
  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([discountId, eventId])
}

model Sponsor {
  id               String   @id @default(uuid())
  name             String
  productOrTagline String
  logoUrl          String   @db.Text
  websiteUrl       String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(uuid())
  name      String
  role      String
  photoUrl  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id          String               @id @default(uuid())
  name        String?
  email       String
  message     String               @db.LongText
  source      String               @default("public-web")
  ipAddress   String?
  userAgent   String?              @db.Text
  language    String               @default("en")
  status      ContactMessageStatus @default(NEW)
  processedAt DateTime?
  emailSent   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  timestamp    DateTime @default(now())
}

model EventAudit {
  id              String   @id @default(uuid())
  eventId         String
  eventIdSnapshot String
  action          String
  byUserId        String?
  meta            Json?
  timestamp       DateTime @default(now())
}

model EvaluationForm {
  id        String               @id @default(uuid())
  eventId   String               @unique
  questions EvaluationQuestion[]
}

enum EvaluationQuestionType {
  RATING
  TEXT
  YES_NO
}

model EvaluationQuestion {
  id       String                 @id @default(uuid())
  formId   String
  form     EvaluationForm         @relation(fields: [formId], references: [id], onDelete: Cascade)
  type     EvaluationQuestionType
  label    String                 @db.Text
  required Boolean                @default(true)
}

model EvaluationSubmission {
  id               String   @id @default(uuid())
  evaluationFormId String
  userId           String
  eventId          String
  answers          Json
  submittedAt      DateTime @default(now())
}
