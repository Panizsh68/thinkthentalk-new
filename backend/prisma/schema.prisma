
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  EVENT_MANAGER
  FINANCE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EventType {
  ONLINE
  OFFLINE
}

enum TicketType {
  EARLY_BIRD
  STANDARD
  SUPPORTER
}

enum Currency {
  IRR
  TOMAN
}

enum RegistrationStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ResourceAccessLevel {
  PUBLIC
  REGISTERED_ONLY
}

enum EvaluationQuestionType {
  RATING
  TEXT
  YES_NO
}

enum ContactMessageStatus {
  NEW
  SEEN
  ARCHIVED
}

enum EventIdeaType {
  TOPIC
  FORMAT
  VENUE
  OTHER
}

enum EventIdeaStatus {
  PENDING
  REVIEWED
  PLANNED
  REJECTED
}

model AdminUser {
  id           String      @id @default(uuid())
  email        String      @unique
  name         String?
  role         AdminRole   @default(ADMIN)
  password     String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  auditLogs    AdminAuditLog[]
}

model User {
  id              String           @id @default(uuid())
  mobile          String           @unique
  email           String?
  firstNameFa     String
  lastNameFa      String
  firstNameEn     String?
  lastNameEn      String?
  gender          Gender?
  age             Int?
  educationLevel  String?
  fieldOfStudy    String?
  isEmployed      Boolean?
  jobTitle        String?
  languageLevel   String?
  avatarUrl       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  registrations   Registration[]
  submissions     EvaluationSubmission[]
  eventIdeas      EventIdea[]
}

model Event {
  id                    String                @id @default(uuid())
  slug                  String                @unique
  title                 String                @db.Text // JSON LocalizedText
  summaryFa             String                @db.Text
  summaryEn             String?               @db.Text
  descriptionFa         String                @db.LongText
  descriptionEn         String?               @db.LongText
  type                  EventType             @default(ONLINE)
  city                  String?               @db.Text // JSON LocalizedText
  address               String?               @db.Text
  startDateTime         DateTime
  endDateTime           DateTime?
  capacityTotal         Int
  capacityRemaining     Int
  showRemainingCapacity Boolean               @default(false)
  categories            Json
  publicDiscountIds     Json?
  posterUrl             String?               @db.Text
  isArchived            Boolean               @default(false)
  archivedAt            DateTime?
  archivedById          String?
  deletedAt             DateTime?
  deletedById           String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  ticketConfigs         EventTicketConfig[]
  resources             EventResource[]
  registrations         Registration[]
  evaluationForms       EvaluationForm[]
  submissions           EvaluationSubmission[]
  discounts             DiscountOnEvent[]
  auditLogs             EventAudit[]
}

model EventTicketConfig {
  id               String     @id @default(uuid())
  eventId          String
  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type             TicketType
  price            Decimal    @db.Decimal(15, 2)
  currency         Currency   @default(TOMAN)
  quantityTotal    Int
  quantitySold     Int        @default(0)
  saleStartDate    DateTime?
  saleEndDate      DateTime?
  earlyBirdEndDate DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([eventId, type])
}

model EventResource {
  id          String              @id @default(uuid())
  eventId     String
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  titleFa     String
  titleEn     String
  description String?             @db.Text
  accessLevel ResourceAccessLevel @default(PUBLIC)
  url         String              @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Registration {
  id          String             @id @default(uuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  eventId     String
  event       Event              @relation(fields: [eventId], references: [id])
  ticketType  TicketType
  status      RegistrationStatus @default(PENDING)
  formData    Json?
  paymentId   String?            @unique
  payment     Payment?           @relation(fields: [paymentId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([userId, eventId])
}

model Payment {
  id                   String        @id @default(uuid())
  registrationId       String?
  eventId              String
  ticketType           TicketType
  amount               Decimal       @db.Decimal(15, 2)
  currency             Currency      @default(TOMAN)
  status               PaymentStatus @default(PENDING)
  gatewayTransactionId String?       @db.VarChar(255)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  registration         Registration?
}

model Discount {
  id             String            @id @default(uuid())
  name           String
  code           String?           @unique
  type           String // PERCENT, FIXED
  value          Decimal           @db.Decimal(15, 2)
  maxUses        Int?
  usedCount      Int               @default(0)
  maxUsesPerUser Int?
  minAmount      Decimal?          @db.Decimal(15, 2)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean           @default(true)
  isPublic       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  events         DiscountOnEvent[]
}

model DiscountOnEvent {
  discountId String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([discountId, eventId])
}

model Sponsor {
  id          String   @id @default(uuid())
  nameFa      String
  nameEn      String?
  logoUrl     String   @db.Text
  websiteUrl  String?  @db.Text
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(uuid())
  firstNameFa String
  lastNameFa  String
  firstNameEn String?
  lastNameEn  String?
  roleFa      String
  roleEn      String?
  avatarUrl   String?  @db.Text
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EvaluationForm {
  id          String               @id @default(uuid())
  eventId     String
  event       Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  questions   EvaluationQuestion[]
  submissions EvaluationSubmission[]
}

model EvaluationQuestion {
  id        String                 @id @default(uuid())
  formId    String
  form      EvaluationForm         @relation(fields: [formId], references: [id], onDelete: Cascade)
  type      EvaluationQuestionType
  label     String                 @db.Text
  required  Boolean                @default(true)
  order     Int                    @default(0)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
}

model EvaluationSubmission {
  id               String         @id @default(uuid())
  evaluationFormId String
  form             EvaluationForm @relation(fields: [evaluationFormId], references: [id])
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  eventId          String
  event            Event          @relation(fields: [eventId], references: [id])
  answers          Json
  submittedAt      DateTime       @default(now())
}

model ContactMessage {
  id          String               @id @default(uuid())
  name        String?
  email       String
  message     String               @db.Text
  source      String               @default("public-web")
  ipAddress   String?
  userAgent   String?
  language    String               @default("fa")
  status      ContactMessageStatus @default(NEW)
  processedAt DateTime?
  emailSent   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model EventIdea {
  id          String          @id @default(uuid())
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])
  name        String?         // For guest users
  email       String?         // For guest users
  title       String
  description String          @db.Text
  type        EventIdeaType   @default(TOPIC)
  status      EventIdeaStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model AdminAuditLog {
  id           String    @id @default(uuid())
  adminId      String
  admin        AdminUser @relation(fields: [adminId], references: [id])
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  createdAt    DateTime  @default(now())
}

model EventAudit {
  id              String   @id @default(uuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventIdSnapshot String
  action          String
  byUserId        String?
  meta            Json?
  createdAt       DateTime @default(now())
}
