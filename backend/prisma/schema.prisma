generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model AdminUser {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id                    String                 @id @default(uuid())
  mobile                String                 @unique
  firstNameFa           String                 @default("نام")
  lastNameFa            String                 @default("نام خانوادگی")
  firstNameEn           String?
  lastNameEn            String?
  gender                Gender?
  age                   Int?
  educationLevel        String?
  fieldOfStudy          String?
  isEmployed            Boolean?               @default(false)
  jobTitle              String?
  email                 String?                @unique
  languageLevel         String?
  avatarUrl             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  password              String?
  collaborationRequests CollaborationRequest[]
  evaluationSubmissions EvaluationSubmission[]
  eventIdeas            EventIdea[]
  registrations         Registration[]
  sponsorshipRequests   SponsorshipRequest[]
  subscription          Subscription?
  wallet                Wallet?
  withdrawalRequests    WithdrawalRequest[]
}

model Event {
  id                    String                 @id @default(uuid())
  slug                  String                 @unique
  title                 String                 @db.Text
  summaryFa             String                 @db.Text
  summaryEn             String?                @db.Text
  descriptionFa         String                 @db.LongText
  descriptionEn         String?                @db.LongText
  type                  EventType              @default(ONLINE)
  city                  String?                @db.Text
  address               String?                @db.Text
  startDateTime         DateTime
  endDateTime           DateTime?
  capacityTotal         Int
  capacityRemaining     Int
  showRemainingCapacity Boolean                @default(false)
  categories            String?                @db.LongText
  publicDiscountIds     String?                @db.LongText
  posterUrl             String?
  isArchived            Boolean                @default(false)
  archivedAt            DateTime?
  archivedById          String?
  deletedAt             DateTime?
  deletedById           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  discounts             DiscountOnEvent[]
  evaluationForm        EvaluationForm?
  evaluationSubmissions EvaluationSubmission[]
  eventAudits           EventAudit[]
  resources             EventResource[]
  ticketConfigs         EventTicketConfig[]
  registrations         Registration[]
}

model EventTicketConfig {
  id               String     @id @default(uuid())
  eventId          String
  type             TicketType
  price            Decimal    @db.Decimal(15, 2)
  currency         Currency   @default(TOMAN)
  quantityTotal    Int
  quantitySold     Int        @default(0)
  saleStartDate    DateTime?
  saleEndDate      DateTime?
  earlyBirdEndDate DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, type])
}

model EventResource {
  id          String              @id @default(uuid())
  eventId     String
  titleFa     String
  titleEn     String
  accessLevel ResourceAccessLevel @default(PUBLIC)
  url         String
  description String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId], map: "EventResource_eventId_fkey")
}

model Registration {
  id         String             @id @default(uuid())
  userId     String
  eventId    String
  ticketType TicketType
  status     RegistrationStatus @default(PENDING)
  formData   String?            @db.LongText
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  payment    Payment?
  event      Event              @relation(fields: [eventId], references: [id])
  user       User               @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
}

model Payment {
  id                   String        @id @default(uuid())
  registrationId       String        @unique
  eventId              String
  ticketType           TicketType
  amount               Decimal       @db.Decimal(15, 2)
  currency             Currency      @default(TOMAN)
  status               PaymentStatus @default(PENDING)
  gatewayTransactionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  registration         Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model Discount {
  id             String            @id @default(uuid())
  name           String
  code           String?           @unique
  type           DiscountType
  value          Decimal           @db.Decimal(15, 2)
  maxUses        Int?
  usedCount      Int               @default(0)
  maxUsesPerUser Int?
  minAmount      Decimal?          @db.Decimal(15, 2)
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean           @default(true)
  isPublic       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  events         DiscountOnEvent[]
}

model DiscountOnEvent {
  discountId String
  eventId    String
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([discountId, eventId])
  @@index([eventId], map: "DiscountOnEvent_eventId_fkey")
}

model EvaluationForm {
  id          String                 @id @default(uuid())
  eventId     String                 @unique
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  event       Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  questions   EvaluationQuestion[]
  submissions EvaluationSubmission[]
}

model EvaluationQuestion {
  id       String                 @id @default(uuid())
  formId   String
  type     EvaluationQuestionType
  label    String
  required Boolean                @default(true)
  order    Int                    @default(0)
  form     EvaluationForm         @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId], map: "EvaluationQuestion_formId_fkey")
}

model EvaluationSubmission {
  id               String         @id @default(uuid())
  evaluationFormId String
  userId           String
  eventId          String
  answers          String         @db.LongText
  submittedAt      DateTime       @default(now())
  form             EvaluationForm @relation(fields: [evaluationFormId], references: [id], onDelete: Cascade)
  event            Event          @relation(fields: [eventId], references: [id])
  user             User           @relation(fields: [userId], references: [id])

  @@index([evaluationFormId])
  @@index([eventId], map: "EvaluationSubmission_eventId_fkey")
  @@index([userId])
}

model ContactMessage {
  id          String               @id @default(uuid())
  name        String?
  email       String
  message     String               @db.Text
  source      String               @default("public-web")
  ipAddress   String?
  userAgent   String?
  language    String               @default("fa")
  status      ContactMessageStatus @default(NEW)
  processedAt DateTime?
  emailSent   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model EventAudit {
  id              String   @id @default(uuid())
  eventId         String
  eventIdSnapshot String
  action          String
  byUserId        String?
  meta            String?  @db.LongText
  createdAt       DateTime @default(now())
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId], map: "EventAudit_eventId_fkey")
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  resourceType String
  resourceId   String
  metadata     String?  @db.LongText
  createdAt    DateTime @default(now())
}

model EventIdea {
  id          String          @id @default(uuid())
  userId      String?
  name        String?
  email       String?
  title       String
  description String          @db.Text
  type        EventIdeaType
  status      EventIdeaStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User?           @relation(fields: [userId], references: [id])

  @@index([userId], map: "EventIdea_userId_fkey")
}

model CollaborationRequest {
  id               String            @id @default(uuid())
  userId           String?
  name             String
  email            String
  mobile           String
  fieldOfExpertise String
  experience       String?           @db.Text
  whyJoin          String            @db.Text
  availability     String?
  acceptedTerms    Boolean           @default(false)
  status           PartnershipStatus @default(PENDING)
  notes            String?           @db.Text
  processedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User?             @relation(fields: [userId], references: [id])

  @@index([userId], map: "CollaborationRequest_userId_fkey")
}

model SponsorshipRequest {
  id                 String            @id @default(uuid())
  userId             String?
  companyName        String
  representativeName String
  email              String
  mobile             String
  plan               SponsorshipPlan
  description        String?           @db.Text
  status             PartnershipStatus @default(PENDING)
  notes              String?           @db.Text
  processedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User?             @relation(fields: [userId], references: [id])

  @@index([userId], map: "SponsorshipRequest_userId_fkey")
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  balance      Decimal             @default(0.00) @db.Decimal(15, 2)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String
  amount      Decimal               @db.Decimal(15, 2)
  type        WalletTransactionType
  description String?
  status      PaymentStatus         @default(SUCCESS)
  referenceId String?
  createdAt   DateTime              @default(now())
  wallet      Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId], map: "WalletTransaction_walletId_fkey")
}

model WithdrawalRequest {
  id          String           @id @default(uuid())
  userId      String
  amount      Decimal          @db.Decimal(15, 2)
  shabaNumber String
  status      WithdrawalStatus @default(PENDING)
  adminNote   String?          @db.Text
  processedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id])

  @@index([userId], map: "WithdrawalRequest_userId_fkey")
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  name         String
  description  String?  @db.Text
  price        Decimal  @db.Decimal(15, 2)
  durationDays Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  planName  String
  startDate DateTime @default(now())
  endDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Sponsor {
  id         String   @id @default(uuid())
  nameFa     String
  logoUrl    String
  websiteUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(uuid())
  firstNameFa String
  lastNameFa  String
  roleFa      String
  avatarUrl   String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

enum AdminRole {
  ADMIN
  EVENT_MANAGER
  FINANCE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RegistrationStatus {
  PAID
  PENDING
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum Currency {
  IRR
  TOMAN
}

enum ResourceAccessLevel {
  PUBLIC
  REGISTERED_ONLY
}

enum EventType {
  ONLINE
  OFFLINE
}

enum EventIdeaType {
  TOPIC
  FORMAT
  VENUE
  OTHER
}

enum EventIdeaStatus {
  PENDING
  REVIEWED
  PLANNED
  REJECTED
}

enum PartnershipStatus {
  PENDING
  REVIEWING
  CONTACTED
  ACCEPTED
  REJECTED
}

enum SponsorshipPlan {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  PURCHASE
  REFUND
  SUBSCRIPTION
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketType {
  EARLY_BIRD
  STANDARD
  SUPPORTER
}

enum DiscountType {
  PERCENT
  FIXED
}

enum EvaluationQuestionType {
  RATING
  TEXT
  YES_NO
}

enum ContactMessageStatus {
  NEW
  SEEN
  ARCHIVED
}
