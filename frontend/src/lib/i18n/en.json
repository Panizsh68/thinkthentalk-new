  "faq": {
    "title": "Frequently Asked Questions",
    "subtitle": "Everything you need to know about our community and events.",
    "categories": {
      "general": "General",
      "registration": "Registration & Payment",
      "events": "Events"
    },
    "questions": {
      "whatIs": {
        "q": "What is Think Then Talk?",
        "a": "Think Then Talk is a dynamic community for English learners and enthusiasts to practice speaking, build confidence, and connect with others through structured discussions and social events."
      },
      "howToJoin": {
        "q": "How can I join the community?",
        "a": "Joining is easy! Just browse our upcoming events, pick one that interests you, and register. You'll become a member of our growing community automatically."
      },
      "isRegistrationRequired": {
        "q": "Is registration required for every event?",
        "a": "Yes, to ensure the quality of discussions and manage capacity, registration is required for all our sessions."
      },
      "howToPay": {
        "q": "How can I pay for events?",
        "a": "We use a token system called Talk Coins. You can purchase coins in our Coin Center and use them to register for any event or purchase a community pass."
      },
      "onlineOrOffline": {
        "q": "Are the events online or in-person?",
        "a": "We offer both! We have online sessions for global accessibility and in-person meetups in various cities. Each event page clearly states the format."
      },
      "refundPolicy": {
        "q": "What is the refund policy?",
        "a": "Talk Coins are non-refundable. However, if an event is cancelled by us, we will return the coins used for that specific registration to your balance."
      }
    }
  },
